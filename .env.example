# ════════════════════════════════════════════════════════════════
# EasySlip HR Platform — Environment Variables Template
# ────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` (already in .gitignore).
#
# Multi-tenant silo architecture:
#   • Control-plane DB  = platform-wide (tenants, billing, audit)
#   • Tenant DB         = per-tenant isolated schema (employees, leave, …)
# ════════════════════════════════════════════════════════════════


# ┌──────────────────────────────────────────────────────────────┐
# │ 1. CONTROL-PLANE DATABASE (NeonDB — platform-wide)           │
# ├──────────────────────────────────────────────────────────────┤
# │ Stores: tenants, plans, billing, trials, platform team       │
# │ Where to get:                                                │
# │   https://console.neon.tech → Create project "hr-platform"   │
# │   → Connection Details                                       │
# │   - "Pooled connection"  → CONTROL_PLANE_DATABASE_URL        │
# │   - "Direct connection"  → CONTROL_PLANE_DIRECT_URL          │
# └──────────────────────────────────────────────────────────────┘
CONTROL_PLANE_DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/platform?sslmode=require&pgbouncer=true&connect_timeout=15"
CONTROL_PLANE_DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/platform?sslmode=require"

# AES-256 key for encrypting sensitive tenant connection strings.
# Generate with:  openssl rand -hex 32   (must be exactly 64 hex chars)
CONTROL_PLANE_ENCRYPTION_KEY="<paste-output-from-openssl-rand-hex-32>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 2. TENANT DATABASE (NeonDB — per-tenant)                     │
# ├──────────────────────────────────────────────────────────────┤
# │ Stores: employees, attendance, leave, OT, payroll            │
# │ In dev, point both to the same NeonDB project with a         │
# │ separate schema or database name.                            │
# │ In production, each tenant gets its own NeonDB project.      │
# └──────────────────────────────────────────────────────────────┘
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<tenant_db>?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<tenant_db>?sslmode=require"


# ┌──────────────────────────────────────────────────────────────┐
# │ 3. NEXTAUTH v5 (Auth.js)                                     │
# ├──────────────────────────────────────────────────────────────┤
# │ AUTH_SECRET: openssl rand -base64 32  (or: bunx auth secret) │
# │ AUTH_URL: base URL of the app — for dev use localhost:3000   │
# │ AUTH_TRUST_HOST: must be true behind Vercel / reverse-proxy  │
# └──────────────────────────────────────────────────────────────┘
AUTH_SECRET="<paste-output-from-openssl-rand-base64-32>"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"


# ┌──────────────────────────────────────────────────────────────┐
# │ 4. MULTI-TENANT ROUTING                                      │
# ├──────────────────────────────────────────────────────────────┤
# │ ROOT_DOMAIN: apex domain. Subdomains are {slug}.ROOT_DOMAIN  │
# │   Dev:  localhost:3000  (subdomain routing via /etc/hosts    │
# │         or a tool like localias / Caddy)                     │
# │   Prod: easyslip.app                                         │
# │                                                              │
# │ How subdomain routing works in dev:                          │
# │   1. Add to /etc/hosts:                                      │
# │        127.0.0.1  demo.localhost                             │
# │   2. Open http://demo.localhost:3000                         │
# │      middleware reads the subdomain → loads tenant DB        │
# └──────────────────────────────────────────────────────────────┘
ROOT_DOMAIN="localhost:3000"


# ┌──────────────────────────────────────────────────────────────┐
# │ 5. PLATFORM / SUPERADMIN PORTAL                              │
# ├──────────────────────────────────────────────────────────────┤
# │ Superadmin portal lives at /platform (no subdomain).         │
# │ PLATFORM_ADMIN_EMAIL + PASSWORD: seed credentials for the    │
# │   first platform admin (created by `bun run db:seed:platform`)│
# │ PLATFORM_SUPPORT_EMAIL + PASSWORD: secondary support account │
# │ PLATFORM_SESSION_SECRET: signs the platform-only JWT cookie  │
# │   Generate with: openssl rand -hex 32  (min 32 chars)        │
# │ TRIAL_DURATION_DAYS: default trial length for new tenants    │
# │ SIGNUP_NOTIFICATION_EMAIL: alert destination for new signups │
# └──────────────────────────────────────────────────────────────┘
PLATFORM_ADMIN_EMAIL="admin@easyslip.app"
PLATFORM_ADMIN_PASSWORD="<strong-password>"
PLATFORM_SUPPORT_EMAIL="support@easyslip.app"
PLATFORM_SUPPORT_PASSWORD="<strong-password>"
PLATFORM_SESSION_SECRET="<paste-output-from-openssl-rand-hex-32>"
TRIAL_DURATION_DAYS="14"
SIGNUP_NOTIFICATION_EMAIL="alerts@easyslip.app"
ALERT_EMAIL="ops@easyslip.app"


# ┌──────────────────────────────────────────────────────────────┐
# │ 6. IMPERSONATION (Superadmin → Tenant)                       │
# ├──────────────────────────────────────────────────────────────┤
# │ IMPERSONATION_COOKIE_VALUE: static sentinel value written     │
# │   into the impersonation cookie so middleware can detect an  │
# │   active impersonation session.                              │
# │   Generate with: openssl rand -hex 16                        │
# │   Required by E2E tests: tests skip if not set.              │
# └──────────────────────────────────────────────────────────────┘
IMPERSONATION_COOKIE_VALUE="<paste-output-from-openssl-rand-hex-16>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 7. RESEND (Transactional Email)                              │
# ├──────────────────────────────────────────────────────────────┤
# │ Where to get: https://resend.com → API Keys → Create API Key │
# │ EMAIL_FROM: must be a verified domain on Resend              │
# │   Dev: onboarding@resend.dev (owner inbox only, free tier)   │
# │   Prod: no-reply@easyslip.app (DNS records required)         │
# │ RESEND_OWNER_EMAIL: fallback recipient for dev-only alerts   │
# └──────────────────────────────────────────────────────────────┘
RESEND_API_KEY="re_<your_resend_api_key>"
EMAIL_FROM="EasySlip <onboarding@resend.dev>"
RESEND_OWNER_EMAIL="dev@example.com"


# ┌──────────────────────────────────────────────────────────────┐
# │ 8. VERCEL BLOB (File Storage)                                │
# ├──────────────────────────────────────────────────────────────┤
# │ Vercel Dashboard → Storage → Create Blob → Connect project   │
# │ Pull token: bunx vercel env pull .env.local                  │
# └──────────────────────────────────────────────────────────────┘
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_<your_token>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 9. WEB PUSH / VAPID (Push Notifications)                     │
# ├──────────────────────────────────────────────────────────────┤
# │ Generate key pair (run once, store securely):                │
# │   npx web-push generate-vapid-keys                           │
# │ VAPID_SUBJECT: mailto URI shown in push subscription         │
# └──────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_VAPID_PUBLIC_KEY="<your_vapid_public_key>"
VAPID_PUBLIC_KEY="<your_vapid_public_key>"
VAPID_PRIVATE_KEY="<your_vapid_private_key>"
VAPID_SUBJECT="mailto:hr@easyslip.app"


# ┌──────────────────────────────────────────────────────────────┐
# │ 10. CRON SECRET (Vercel Cron auth)                           │
# ├──────────────────────────────────────────────────────────────┤
# │ Protects /api/v1/system/cron/* routes.                       │
# │ Generate with: openssl rand -hex 32                          │
# └──────────────────────────────────────────────────────────────┘
CRON_SECRET="<paste-output-from-openssl-rand-hex-32>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 11. APP CONFIG (Public — exposed to browser)                 │
# ├──────────────────────────────────────────────────────────────┤
# │ NEXT_PUBLIC_* vars are bundled into the client bundle.       │
# │ Never put secrets here.                                      │
# └──────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_APP_NAME="EasySlip HR"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_TIMEZONE="Asia/Bangkok"
NEXT_PUBLIC_DEFAULT_LOCALE="th-TH"


# ┌──────────────────────────────────────────────────────────────┐
# │ 12. BUSINESS RULES                                           │
# └──────────────────────────────────────────────────────────────┘
CUTOFF_DAY_OF_MONTH="25"
ANNUAL_LEAVE_FULL_YEAR_DAYS="6"
ROUNDING_STEP="0.5"
DAYS_IN_YEAR_BASIS="365"


# ┌──────────────────────────────────────────────────────────────┐
# │ 13. EMPEO PAYROLL INTEGRATION                                │
# └──────────────────────────────────────────────────────────────┘
EMPEO_EXPORT_OUTPUT_DIR="./tmp/empeo-exports"
# EMPEO_WEBHOOK_URL=""          # https://api.empeo.example.com/easyslip
# EMPEO_WEBHOOK_SECRET=""       # openssl rand -hex 32 (shared with Empeo)


# ┌──────────────────────────────────────────────────────────────┐
# │ 14. FEATURE FLAGS                                            │
# └──────────────────────────────────────────────────────────────┘
FEATURE_MAGIC_LINK_ENABLED="true"
FEATURE_PDPA_CONSENT_REQUIRED="true"
FEATURE_GPS_CAPTURE_ENABLED="true"
FEATURE_AUDIT_LOG_ENABLED="true"


# ┌──────────────────────────────────────────────────────────────┐
# │ 15. DEV TOOLS                                                │
# └──────────────────────────────────────────────────────────────┘
LOG_LEVEL="debug"
SEED_DEMO_DATA="true"


# ┌──────────────────────────────────────────────────────────────┐
# │ 16. E2E TESTS (Playwright)                                   │
# ├──────────────────────────────────────────────────────────────┤
# │ E2E_TEST_SECRET: gates /api/v1/system/test-auth (dev only)   │
# │ E2E_TENANT_SLUG: slug of the demo tenant used in tests       │
# │ E2E_TENANT_ADMIN_EMAIL: HRMG/TENANT_ADMIN user in that tenant│
# │ E2E_TENANT_EMPLOYEE_EMAIL: plain EMPLOYEE user (RBAC tests)  │
# │ E2E_TENANT_B_SLUG: second tenant slug (cross-tenant isolation)│
# └──────────────────────────────────────────────────────────────┘
E2E_TEST_SECRET="<paste-output-from-openssl-rand-hex-16>"
E2E_TENANT_SLUG="demo"
E2E_TENANT_ADMIN_EMAIL="admin@demo.easyslip.app"
E2E_TENANT_EMPLOYEE_EMAIL="employee@demo.easyslip.app"
# E2E_TENANT_B_SLUG="acme"     # optional: second tenant for isolation tests


# ┌──────────────────────────────────────────────────────────────┐
# │ 17. SENTRY (Optional — no-ops if DSN is unset)               │
# └──────────────────────────────────────────────────────────────┘
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""


# Phase 2 placeholders:
# S3_BUCKET=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
