# ════════════════════════════════════════════════════════════════
# EasySlip HR Platform — Environment Variables Template
# ────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` (already in .gitignore).
#
# Architecture (path-based multi-tenant + branch-per-tenant):
#   • Control Plane DB  = platform-wide (User, Tenant, Session, Membership)
#   • Tenant DB         = one Neon BRANCH per tenant inside a single
#                         project; URLs stored encrypted in CP DB
#   • Routing           = path-based  /{slug}/...  (NOT subdomain)
# ════════════════════════════════════════════════════════════════


# ┌──────────────────────────────────────────────────────────────┐
# │ 1. CONTROL PLANE DATABASE (NeonDB — platform-wide)           │
# ├──────────────────────────────────────────────────────────────┤
# │ Stores: User, Session, Account, Tenant, TenantMembership,    │
# │         PlatformAuditLog, TrialSignup, Impersonation, Plan   │
# │ Where to get:                                                │
# │   https://console.neon.tech → Create project                 │
# │   → Connection Details                                       │
# │   - "Pooled connection"  → CONTROL_PLANE_DATABASE_URL        │
# │   - "Direct connection"  → CONTROL_PLANE_DIRECT_URL          │
# └──────────────────────────────────────────────────────────────┘
CONTROL_PLANE_DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require"
CONTROL_PLANE_DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require"

# AES-256 key for encrypting per-tenant connection URIs stored in CP DB.
# Generate with:  openssl rand -hex 32   (must be exactly 64 hex chars)
CONTROL_PLANE_ENCRYPTION_KEY="<paste-output-from-openssl-rand-hex-32>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 2. TENANT TEMPLATE DATABASE (dev + migrations only)          │
# ├──────────────────────────────────────────────────────────────┤
# │ At runtime each tenant uses a Neon branch (URL fetched from  │
# │ CP DB Tenant.databaseUrlEnc). These vars are used ONLY for:  │
# │   • `prisma migrate dev`  on the tenant schema               │
# │   • Local dev work against a seed/template tenant            │
# │ Point to your parent (template) branch — that branch is the  │
# │ source from which new tenant branches are cloned.            │
# └──────────────────────────────────────────────────────────────┘
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<template_db>?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<template_db>?sslmode=require&channel_binding=require"


# ┌──────────────────────────────────────────────────────────────┐
# │ 3. NEXTAUTH v5 (Auth.js)                                     │
# ├──────────────────────────────────────────────────────────────┤
# │ AUTH_SECRET: openssl rand -base64 32  (or: bunx auth secret) │
# │ AUTH_URL: base URL — must match the app origin               │
# │ AUTH_TRUST_HOST: true behind Vercel / reverse-proxy          │
# │ NEXTAUTH_URL: legacy alias still read by two email senders;  │
# │   set the same value as AUTH_URL to keep email links right.  │
# └──────────────────────────────────────────────────────────────┘
AUTH_SECRET="<paste-output-from-openssl-rand-base64-32>"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"


# ┌──────────────────────────────────────────────────────────────┐
# │ 4. APP URLs                                                  │
# ├──────────────────────────────────────────────────────────────┤
# │ APP_URL: server-side absolute base (welcome emails,          │
# │   impersonation redirects, signup confirmation links).       │
# │ NEXT_PUBLIC_APP_URL: bundled into the browser bundle.        │
# └──────────────────────────────────────────────────────────────┘
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EasySlip HR"
NEXT_PUBLIC_DEFAULT_TIMEZONE="Asia/Bangkok"
NEXT_PUBLIC_DEFAULT_LOCALE="th-TH"


# ┌──────────────────────────────────────────────────────────────┐
# │ 5. PLATFORM / SUPERADMIN PORTAL                              │
# ├──────────────────────────────────────────────────────────────┤
# │ Lives at /platform/* (path-based; no subdomain).             │
# │ PLATFORM_ADMIN_*   : seeded by `scripts/seed-platform-admin` │
# │ PLATFORM_SUPPORT_* : seeded by `scripts/seed-platform-support`│
# │ PLATFORM_SESSION_SECRET: signs platform-only JWT cookie      │
# │   (also signs impersonation JWTs). Min 32 chars.             │
# │   Generate with: openssl rand -hex 32                        │
# │ TRIAL_DURATION_DAYS: default trial length for new tenants    │
# │ SIGNUP_NOTIFICATION_EMAIL: alert dest for new signups        │
# │ ALERT_EMAIL: outbox-service failure alerts                   │
# └──────────────────────────────────────────────────────────────┘
PLATFORM_ADMIN_EMAIL="admin@easyslip.app"
PLATFORM_ADMIN_PASSWORD="<strong-password>"
PLATFORM_SUPPORT_EMAIL="support@easyslip.app"
PLATFORM_SUPPORT_PASSWORD="<strong-password>"
PLATFORM_SESSION_SECRET="<paste-output-from-openssl-rand-hex-32>"
TRIAL_DURATION_DAYS="30"
SIGNUP_NOTIFICATION_EMAIL="alerts@easyslip.app"
ALERT_EMAIL="ops@easyslip.app"


# ┌──────────────────────────────────────────────────────────────┐
# │ 6. IMPERSONATION (SuperAdmin → Tenant)                       │
# ├──────────────────────────────────────────────────────────────┤
# │ IMPERSONATION_REQUIRE_APPROVAL:                              │
# │   "true"  (default) — tenant admin must approve via email    │
# │   "false"           — dev bypass: launch directly            │
# │ IMPERSONATION_APPROVAL_TTL_MIN: minutes before consent expires│
# │   (default: 30)                                              │
# └──────────────────────────────────────────────────────────────┘
IMPERSONATION_REQUIRE_APPROVAL="true"
IMPERSONATION_APPROVAL_TTL_MIN="30"


# ┌──────────────────────────────────────────────────────────────┐
# │ 7. NEON API (self-service tenant provisioning)               │
# ├──────────────────────────────────────────────────────────────┤
# │ Used when a new tenant signs up: creates a Neon branch,      │
# │ runs prisma migrate deploy, seeds the admin user.            │
# │ Where to get:                                                │
# │   https://console.neon.tech → Account Settings → API Keys    │
# │ NEON_PROJECT_ID: the single project that holds all tenant   │
# │   branches (NOT the CP project — separate project).          │
# │ NEON_PARENT_BRANCH_ID: branch new tenants are cloned from   │
# │   (typically your "template" or "main" branch ID).           │
# │ NEON_BRANCH_ROLE_NAME: DB role inside each branch            │
# │   (Neon default: neondb_owner)                               │
# └──────────────────────────────────────────────────────────────┘
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_PARENT_BRANCH_ID=""
NEON_BRANCH_ROLE_NAME="neondb_owner"
NEON_DATABASE_NAME="neondb"
NEON_API_BASE_URL="https://console.neon.tech/api/v2"


# ┌──────────────────────────────────────────────────────────────┐
# │ 8. RESEND (Transactional Email)                              │
# ├──────────────────────────────────────────────────────────────┤
# │ Where to get: https://resend.com → API Keys → Create API Key │
# │ EMAIL_FROM: must be a verified domain on Resend              │
# │   Dev: onboarding@resend.dev (free tier only delivers to     │
# │        the account owner — see RESEND_OWNER_EMAIL below)     │
# │   Prod: no-reply@easyslip.app (DNS records required)         │
# │ RESEND_OWNER_EMAIL: fallback recipient for dev-only          │
# │   notifications (used by E2E marketing test)                 │
# └──────────────────────────────────────────────────────────────┘
RESEND_API_KEY="re_<your_resend_api_key>"
EMAIL_FROM="EasySlip <onboarding@resend.dev>"
RESEND_OWNER_EMAIL="dev@example.com"


# ┌──────────────────────────────────────────────────────────────┐
# │ 9. WEB PUSH / VAPID (Push Notifications)                     │
# ├──────────────────────────────────────────────────────────────┤
# │ Generate key pair once (store securely):                     │
# │   npx web-push generate-vapid-keys                           │
# │ Browser fetches the public key at runtime via                │
# │ /api/v1/push/vapid-public-key — no NEXT_PUBLIC_ var needed.  │
# │ VAPID_SUBJECT: mailto URI shown in push subscription         │
# └──────────────────────────────────────────────────────────────┘
VAPID_PUBLIC_KEY="<your_vapid_public_key>"
VAPID_PRIVATE_KEY="<your_vapid_private_key>"
VAPID_SUBJECT="mailto:hr@easyslip.app"


# ┌──────────────────────────────────────────────────────────────┐
# │ 10. CRON SECRET (Vercel Cron auth)                           │
# ├──────────────────────────────────────────────────────────────┤
# │ Protects /api/platform/cron/* and /api/v1/system/cron/*      │
# │ routes. Generate with: openssl rand -hex 32                  │
# └──────────────────────────────────────────────────────────────┘
CRON_SECRET="<paste-output-from-openssl-rand-hex-32>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 11. BUSINESS RULES                                           │
# └──────────────────────────────────────────────────────────────┘
CUTOFF_DAY_OF_MONTH="25"
ANNUAL_LEAVE_FULL_YEAR_DAYS="6"
ROUNDING_STEP="0.5"
DAYS_IN_YEAR_BASIS="365"


# ┌──────────────────────────────────────────────────────────────┐
# │ 12. EMPEO PAYROLL INTEGRATION                                │
# ├──────────────────────────────────────────────────────────────┤
# │ EMPEO_EXPORT_OUTPUT_DIR: local dir for generated exports     │
# │ EMPEO_WEBHOOK_URL/SECRET: optional outbound webhook config   │
# └──────────────────────────────────────────────────────────────┘
EMPEO_EXPORT_OUTPUT_DIR="./tmp/empeo-exports"
# EMPEO_WEBHOOK_URL="https://api.empeo.example.com/easyslip"
# EMPEO_WEBHOOK_SECRET="<openssl rand -hex 32 — shared with Empeo>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 13. DEV / SEED                                               │
# ├──────────────────────────────────────────────────────────────┤
# │ LOG_LEVEL: debug | info | warn | error                       │
# │ SEED_DEMO_DATA: "true" to populate demo employees on seed    │
# │ SEED_TENANT_ID: required by prisma/bootstrap-admin.ts and    │
# │   prisma/seed.ts to attach the admin to a specific tenant.   │
# │   Run a single tenant seed: SEED_TENANT_ID=<id> bun run seed │
# └──────────────────────────────────────────────────────────────┘
LOG_LEVEL="debug"
SEED_DEMO_DATA="true"
# SEED_TENANT_ID="<tenant-id-from-cp-db>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 14. E2E TESTS (Playwright)                                   │
# ├──────────────────────────────────────────────────────────────┤
# │ E2E_TEST_SECRET: gates /api/v1/system/test-auth and          │
# │   /api/platform/test-auth (dev-only sign-in shortcut)        │
# │ E2E_BASE_URL: root URL Playwright drives (default localhost) │
# │ E2E_TENANT_SLUG: slug of the demo tenant used in tests       │
# │ E2E_TENANT_ADMIN_EMAIL: HRMG/TENANT_ADMIN user in that tenant│
# │ E2E_TENANT_EMPLOYEE_EMAIL: plain EMPLOYEE user (RBAC tests)  │
# │ E2E_TENANT_B_SLUG: second tenant slug (isolation tests)      │
# │ E2E_PLATFORM_EMAIL: SUPERADMIN user in CP DB                 │
# │ E2E_SUPPORT_EMAIL: SUPPORT-role platform user (RBAC test)    │
# │ E2E_IMPERSONATE_TENANT_SLUG: tenant to impersonate (defaults │
# │   to E2E_TENANT_SLUG if unset)                               │
# │ IMPERSONATION_COOKIE_VALUE: a valid impersonation JWT        │
# │   (generated from the platform UI). Used by the              │
# │   "end-session" E2E test only — tests skip if unset.         │
# └──────────────────────────────────────────────────────────────┘
E2E_TEST_SECRET="<paste-output-from-openssl-rand-hex-16>"
E2E_BASE_URL="http://localhost:3000"
E2E_TENANT_SLUG="demo"
E2E_TENANT_ADMIN_EMAIL="admin@demo.easyslip.app"
E2E_TENANT_EMPLOYEE_EMAIL="employee@demo.easyslip.app"
# E2E_TENANT_B_SLUG="acme"
E2E_PLATFORM_EMAIL="superadmin@easyslip.app"
# E2E_SUPPORT_EMAIL="support@easyslip.app"
# E2E_IMPERSONATE_TENANT_SLUG="demo"
# IMPERSONATION_COOKIE_VALUE="<paste fresh JWT from platform UI>"
