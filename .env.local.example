# ════════════════════════════════════════════════════════════════
# EasySlip Internal HR System — Environment Variables Template
# ────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` (already in .gitignore).
# ════════════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────────┐
# │ 1. DATABASE (NeonDB — PostgreSQL)                            │
# ├──────────────────────────────────────────────────────────────┤
# │ Where to get:                                                │
# │   https://console.neon.tech → Project → Connection Details   │
# │   - เลือก "Pooled connection" → ใส่ที่ DATABASE_URL          │
# │   - เลือก "Direct connection" → ใส่ที่ DIRECT_URL            │
# │ ℹ️  Prisma ต้อง 2 URLs:                                       │
# │    • DATABASE_URL = runtime queries (pooled, pgbouncer)      │
# │    • DIRECT_URL   = migrations (bypass pooler)               │
# └──────────────────────────────────────────────────────────────┘
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<dbname>?sslmode=require"


# ┌──────────────────────────────────────────────────────────────┐
# │ 2. NEXTAUTH v5 (Auth.js)                                     │
# ├──────────────────────────────────────────────────────────────┤
# │ AUTH_SECRET: สร้างด้วยคำสั่ง:                                 │
# │   $ openssl rand -base64 32                                  │
# │   (หรือ bunx auth secret)                                    │
# │ AUTH_URL: base URL ของแอป (dev = http://localhost:3000)      │
# │ AUTH_TRUST_HOST: ต้องเป็น true เมื่อรันหลัง reverse-proxy    │
# │   หรือ Vercel preview deployment                             │
# └──────────────────────────────────────────────────────────────┘
AUTH_SECRET="<paste-output-from-openssl-rand-base64-32>"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"


# ┌──────────────────────────────────────────────────────────────┐
# │ 3. RESEND (Magic Link Email Provider)                        │
# ├──────────────────────────────────────────────────────────────┤
# │ Where to get:                                                │
# │   https://resend.com → API Keys → Create API Key             │
# │ EMAIL_FROM: ต้อง verify domain ที่ Resend ก่อน               │
# │   Dev: ใช้ onboarding@resend.dev (free tier, ส่งเข้า inbox   │
# │         ของ account owner เท่านั้น)                          │
# │   Prod: no-reply@easyslip.com (ต้อง add + verify DNS records)│
# └──────────────────────────────────────────────────────────────┘
RESEND_API_KEY="re_<your_resend_api_key>"
EMAIL_FROM="EasySlip <onboarding@resend.dev>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 4. VERCEL BLOB (File storage — profile pictures + documents) │
# ├──────────────────────────────────────────────────────────────┤
# │ Where to get:                                                │
# │   Vercel Dashboard → Storage → Create Blob → Connect to      │
# │   project → Pull token via `bunx vercel env pull .env.local` │
# │ Used by: profile picture upload (Phase 1),                   │
# │   employee documents (Phase 2)                               │
# └──────────────────────────────────────────────────────────────┘
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_<your_token>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 4b. CRON SECRET (Vercel Cron auth)                           │
# ├──────────────────────────────────────────────────────────────┤
# │ Required by all /api/v1/system/cron/* routes (daily-quota,   │
# │ cutoff-lock, audit-prune, orphan-blobs).                     │
# │ Generate with:                                               │
# │   $ openssl rand -hex 32                                     │
# │ Vercel Cron sends "Authorization: Bearer $CRON_SECRET" auto- │
# │ matically. For local manual triggers (POST), set the same    │
# │ header yourself.                                             │
# └──────────────────────────────────────────────────────────────┘
CRON_SECRET="<paste-output-from-openssl-rand-hex-32>"


# ┌──────────────────────────────────────────────────────────────┐
# │ 5. APP CONFIG (Public — ใช้ใน client)                        │
# ├──────────────────────────────────────────────────────────────┤
# │ NEXT_PUBLIC_* จะถูก expose ไปยัง browser — ห้ามใส่ secret    │
# └──────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_APP_NAME="EasySlip HR"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_TIMEZONE="Asia/Bangkok"
NEXT_PUBLIC_DEFAULT_LOCALE="th-TH"


# ┌──────────────────────────────────────────────────────────────┐
# │ 5. BUSINESS RULES (Backend-only)                             │
# ├──────────────────────────────────────────────────────────────┤
# │ CUTOFF_DAY_OF_MONTH: payroll cut-off (Thai Labor + Empeo)    │
# │ ANNUAL_LEAVE_FULL_YEAR_DAYS: quota เต็มปี ตาม พ.ร.บ.         │
# │ ROUNDING_STEP: step สำหรับ round-down (0.5 = ครึ่งวัน)       │
# └──────────────────────────────────────────────────────────────┘
CUTOFF_DAY_OF_MONTH="25"
ANNUAL_LEAVE_FULL_YEAR_DAYS="6"
ROUNDING_STEP="0.5"
DAYS_IN_YEAR_BASIS="365"


# ┌──────────────────────────────────────────────────────────────┐
# │ 6. EMPEO PAYROLL EXPORT (Phase 1 = CSV only, no API)         │
# ├──────────────────────────────────────────────────────────────┤
# │ Phase 1: export CSV ให้ HR download + upload Empeo เอง       │
# │ Phase 2: webhook integration (เก็บ field ไว้ ไม่ใช้ตอนนี้)    │
# └──────────────────────────────────────────────────────────────┘
EMPEO_EXPORT_OUTPUT_DIR="./tmp/empeo-exports"
# EMPEO_WEBHOOK_URL=""          # Phase 2
# EMPEO_WEBHOOK_SECRET=""       # Phase 2


# ┌──────────────────────────────────────────────────────────────┐
# │ 7. FEATURE FLAGS (Dev-only toggles)                          │
# ├──────────────────────────────────────────────────────────────┤
FEATURE_MAGIC_LINK_ENABLED="true"
FEATURE_PDPA_CONSENT_REQUIRED="true"
FEATURE_GPS_CAPTURE_ENABLED="true"
FEATURE_AUDIT_LOG_ENABLED="true"


# ┌──────────────────────────────────────────────────────────────┐
# │ 8. DEV TOOLS (Optional — ลบได้ถ้าไม่ใช้)                     │
# ├──────────────────────────────────────────────────────────────┤
# │ LOG_LEVEL: debug | info | warn | error                       │
# │ SEED_DEMO_DATA: true = run เพิ่ม mock เมื่อ `bun db:seed`    │
# └──────────────────────────────────────────────────────────────┘
LOG_LEVEL="debug"
SEED_DEMO_DATA="true"


# ┌──────────────────────────────────────────────────────────────┐
# │ 9. E2E TESTS (Optional — เฉพาะตอนรัน Playwright)             │
# ├──────────────────────────────────────────────────────────────┤
# │ Required by `bun run test:e2e` — gates the test-only login   │
# │ shortcut at /api/v1/system/test-auth. Without it, the route  │
# │ returns 404 (intentional security guard for prod) and every  │
# │ E2E test that needs login fails.                             │
# │ Generate with:                                               │
# │   $ openssl rand -hex 16                                     │
# │ Set NODE_ENV=development or test for the route to be active. │
# └──────────────────────────────────────────────────────────────┘
E2E_TEST_SECRET="<paste-output-from-openssl-rand-hex-16>"


# Phase 2 placeholders (ไม่ต้องใส่ตอนนี้):
# SENTRY_DSN=""
# S3_BUCKET=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
